    "jiti": "^2.6.1",
    "ts-morph": "^27.0.2",
    "ws": "^8.19.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.15",
    "@types/ws": "^8.18.1"
  }
