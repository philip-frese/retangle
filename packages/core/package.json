{
  "name": "@retangle/core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "retangle": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc --build && tsc-alias -p tsconfig.json",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@retangle/types": "*",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
