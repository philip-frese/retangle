{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "paths": {
      "@retangle-types/*": ["./packages/types/*"],
      "@retangle-core/*": ["./packages/core/*"],
      "@retangle-ui/*": ["./packages/ui"] 
    }
  },
  "exclude": [
    "node_modules",
    "**/dist",
    "**/*.test.ts"
  ]
}
